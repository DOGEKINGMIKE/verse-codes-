    RoundFloat(Value:float, DecimalPlaces:int):float =
        Multiplier := Pow(10.0, DecimalPlaces * 1.0)
        var RoundedValues : float = 0.0
        if(RoundedValuess := Round[Value * Multiplier] * 1.0):
                set RoundedValues  = RoundedValuess
        return RoundedValues / Multiplier
    FloorFloat2Decimals(Value:float):string=
        floatString := ToString(Value)
        var stringToReturn:string=""
        for(Char:floatString):
            if(stringToReturn.Length < 4):
                set stringToReturn += "{Char}"
        return stringToReturn
    AddKillsButton(Agent:agent):void=
        if (PlayerObj := player[Agent], PlayerObj.IsActive[]):
            PlayerStatsManager.InitializePlayer(PlayerObj)
            OnPlayerAdded(Agent)
        if:
            CurrentPlayerStats := PlayerStatsManager.GetPlayerStats[Agent]
            CurrentKills := CurrentPlayerStats.Kills.CurrentValue
            CurrentElo := CurrentPlayerStats.Elo.CurrentValue
        then:
            PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.Elo, ?Value := CurrentElo + RankSettings.Rank_Difficulty.EloGainPerKill)
            PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.Kills, ?Value := CurrentKills + 1)
            UpdateAgentUi(Agent,"Kills") 
            
    AddKills(MaybeAgent:?agent):void=
        if( Agent:= MaybeAgent?, PlayerObj:= player[Agent], PlayerObj.IsActive[]):
            PlayerStatsManager.InitializePlayer(PlayerObj)
            OnPlayerAdded(Agent)
        if:
            Agent := MaybeAgent?
            CurrentPlayerStats := PlayerStatsManager.GetPlayerStats[Agent]
            CurrentKills := CurrentPlayerStats.Kills.CurrentValue
            CurrentElo := CurrentPlayerStats.Elo.CurrentValue
        then:
            PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.Elo, ?Value := CurrentElo + RankSettings.Rank_Difficulty.EloGainPerKill)
            PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.Kills, ?Value := CurrentKills + 1)
            UpdateAgentUi(Agent,"Kills")         
    AddDeaths(Agent:agent):void=
        if (PlayerObj := player[Agent], PlayerObj.IsActive[]):
            PlayerStatsManager.InitializePlayer(PlayerObj)
            OnPlayerAdded(Agent)
        if(CurrentPlayerStats := PlayerStatsManager.GetPlayerStats[Agent],CurrentElo := CurrentPlayerStats.Elo.CurrentValue,CurrentDeaths := CurrentPlayerStats.Deaths.CurrentValue):
           if(CurrentEloDiff: int = CurrentElo - RankSettings.Rank_Difficulty.EloLossPerDeath ,CurrentEloDiff <= 0):
            PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.Elo, ?Value := 0)
            PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.Deaths, ?Value := CurrentDeaths + 1)
           else:
            PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.Elo, ?Value := CurrentElo - RankSettings.Rank_Difficulty.EloLossPerDeath)
            PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.Deaths, ?Value := CurrentDeaths + 1)
            UpdateAgentUi(Agent, "Deaths")

    TrackTimePlayed(Player:player)<suspends>:void=
        loop:
            Sleep(60.0)
            if (not Player.IsActive[]):
                break
            if (FC := Player.GetFortCharacter[]):
                if (Agent := FC.GetAgent[]):
                    if (CurrentPlayerStats := PlayerStatsManager.GetPlayerStats[Agent]):
                        CurrentTime := CurrentPlayerStats.TimePlayed.CurrentValue
                        PlayerStatsManager.RecordPlayerStat(Agent, RankStatType.TimePlayed, ?Value := CurrentTime + 1)
                
    OnPlayerLeft(LeftPlayer:player):void = {}

    OnBegin<override>()<suspends>:void=
        Sleep(0.0)
        initializeSpawners()
        Playspace : fort_playspace = GetPlayspace()
        Players := Playspace.GetPlayers()
        PlayerStatsManager.InitializeAllPlayers(Players)
        for(Player:Players):
            if (Player.IsActive[], Agent := agent[Player]):
                OnPlayerAdded(Agent)
                OnPlayerSpawned(Agent)
                spawn{TrackTimePlayed(Player)}
        RankSettings.Display_Stats.DisplayPlayerStatsButton.InteractedWithEvent.Subscribe(ShowStatsLocation1)
        RankSettings.Display_Stats.DisplayPlayerStatsButton2.InteractedWithEvent.Subscribe(ShowStatsLocation2)
        for (ElimManager : RankSettings.Rank_Difficulty.Elimination_Managers):
            ElimManager.EliminatedEvent.Subscribe(AddDeaths)
            ElimManager.EliminationEvent.Subscribe(AddKills)
        RankSettings.Debugger_Testing.AddKillsButtom.InteractedWithEvent.Subscribe(AddKillsButton)
        RankSettings.Debugger_Testing.AddDeathsButton.InteractedWithEvent.Subscribe(AddDeaths)
        GetPlayspace().PlayerRemovedEvent().Subscribe(OnPlayerLeft)
 
        loop:
            Sleep(0.0)
            AddedPlayer:= Playspace.PlayerAddedEvent().Await()
            if (P := player[AddedPlayer], P.IsActive[]):
                PlayerStatsManager.InitializePlayer(P)
            OnPlayerAdded(AddedPlayer)
            OnPlayerSpawned(AddedPlayer)
            if (P := player[AddedPlayer], P.IsActive[]):
                spawn{TrackTimePlayed(P)}
            initializeAllPowerUp()
    
    ShowStatsLocation1(Agent:agent):void=
        if (Player := player[Agent], Player.IsActive[]):
            ShowIndividualStats(Player, 1)
            spawn{AutoHideStats(1, 5.0)}
    
    ShowStatsLocation2(Agent:agent):void=
        if (Player := player[Agent], Player.IsActive[]):
            ShowIndividualStats(Player, 2)
            spawn{AutoHideStats(2, 5.0)}
    
    ShowIndividualStats(Player:player, Location:int):void=
        if (Player.IsActive[], CurrentPlayerStats := PlayerStatsManager.GetPlayerStats[agent[Player]]):
            Kills := CurrentPlayerStats.Kills.CurrentValue
            Deaths := CurrentPlayerStats.Deaths.CurrentValue
            Elo := CurrentPlayerStats.Elo.CurrentValue
            Time := CurrentPlayerStats.TimePlayed.CurrentValue
            KD := if (Deaths = 0):
                Kills * 1.0
            else:
                (Kills * 1.0) / (Deaths * 1.0)
            
            KillsBB := if (Location = 1):
                RankSettings.Display_Stats.KillsBillboard
            else:
                RankSettings.Display_Stats.KillsBillboard2
            DeathsBB := if (Location = 1):
                RankSettings.Display_Stats.DeathsBillboard
            else:
                RankSettings.Display_Stats.DeathsBillboard2
            EloBB := if (Location = 1):
                RankSettings.Display_Stats.EloBillboard
            else:
                RankSettings.Display_Stats.EloBillboard2
            KDBB := if (Location = 1):
                RankSettings.Display_Stats.KDBillboard
            else:
                RankSettings.Display_Stats.KDBillboard2
            TimeBB := if (Location = 1):
                RankSettings.Display_Stats.TimeBillboard
            else:
                RankSettings.Display_Stats.TimeBillboard2
            
            KillsBB.ShowText()
            KillsBB.SetText(KillsMessage(Kills))
            
            DeathsBB.ShowText()
            DeathsBB.SetText(DeathsMessage(Deaths))
            
            EloBB.ShowText()
            EloBB.SetText(EloMessage(Elo))
            
            KDBB.ShowText()
            KDBB.SetText(KDMessage(KD))
            
            TimeBB.ShowText()
            TimeBB.SetText(TimeMessage(Time))
    
    AutoHideStats(Location:int, Duration:float)<suspends>:void=
        Sleep(Duration)
        HideIndividualStats(Location)
    
    HideIndividualStats(Location:int):void=
        KillsBB := if (Location = 1):
            RankSettings.Display_Stats.KillsBillboard
        else:
            RankSettings.Display_Stats.KillsBillboard2
        DeathsBB := if (Location = 1):
            RankSettings.Display_Stats.DeathsBillboard
        else:
            RankSettings.Display_Stats.DeathsBillboard2
        EloBB := if (Location = 1):
            RankSettings.Display_Stats.EloBillboard
        else:
            RankSettings.Display_Stats.EloBillboard2
        KDBB := if (Location = 1):
            RankSettings.Display_Stats.KDBillboard
        else:
            RankSettings.Display_Stats.KDBillboard2
        TimeBB := if (Location = 1):
            RankSettings.Display_Stats.TimeBillboard
        else:
            RankSettings.Display_Stats.TimeBillboard2
        
        KillsBB.HideText()
        DeathsBB.HideText()
        EloBB.HideText()
        KDBB.HideText()
        TimeBB.HideText()
 
    initializeSpawners():void=
        for(Spawner:RankSettings.BackBling_Settings.PlayerSpawners):
            Spawner.SpawnedEvent.Subscribe(initializePowerUp)
    initializeAllPowerUp():void=
        for(Player:GetPlayspace().GetPlayers()):
            if (Player.IsActive[], CustomPlayer:Custom_Player_Rank = PlayerRankUi[Player]):
                CustomPlayer.initializePowerUp()      
    initializePowerUp(Player:agent):void=
        if (PlayerObj := player[Player], PlayerObj.IsActive[]):
            PlayerStatsManager.InitializePlayer(PlayerObj)
            OnPlayerAdded(Player)         
        if (PlayerObj := player[Player], CustomPlayer:Custom_Player_Rank = PlayerRankUi[PlayerObj]):
            CustomPlayer.initializePowerUp()      
    OnPlayerSpawned(Agent:agent):void=
        if(FC:fort_character = Agent.GetFortCharacter[]):
            FC.EliminatedEvent().Subscribe(OnEliminated)
      
    OnEliminated(Result:elimination_result):void=
        Eliminator := Result.EliminatingCharacter
        Elimniated := Result.EliminatedCharacter
       
        if(EliminatorChar : fort_character = Eliminator?):
            if(AgentObj:=EliminatorChar.GetAgent[]):
                if (PlayerObj := player[AgentObj], PlayerObj.IsActive[], CustomPlayer:Custom_Player_Rank = PlayerRankUi[PlayerObj]):
                    if(CurrentPlayerStats := PlayerStatsManager.GetPlayerStats[AgentObj]):
                        EliminatorCurrentRank := CustomPlayer.PlayerCurrentRank()
                        EliminatorName := AgentObj
                        Kills:=CurrentPlayerStats.Kills.CurrentValue
                        Deaths:=CurrentPlayerStats.Deaths.CurrentValue
                        Elo := CurrentPlayerStats.Elo.CurrentValue
                        KD:= RoundFloat((CurrentPlayerStats.Kills.CurrentValue *1.0) / (CurrentPlayerStats.Deaths.CurrentValue*1.0),2)
                        if(ElimniatedAgent:=Elimniated.GetAgent[]):
                            if (ElimPlayer := player[ElimniatedAgent], ElimPlayer.IsActive[], ElimniatedCustomPlayer:Custom_Player_Rank = PlayerRankUi[ElimPlayer]):
                                spawn:
                                    ElimniatedCustomPlayer.EnemyStatPopup( EliminatorName, EliminatorCurrentRank,Kills,Deaths,KD)
    
    UpdateAgentUi(Agent:agent,Increment:string):void=
         if(CurrentPlayerStats := PlayerStatsManager.GetPlayerStats[Agent]):
            if(Increment = "Kills",PlayerObj := player[Agent], PlayerObj.IsActive[], CustomPlayer := PlayerRankUi[PlayerObj]):
                CustomPlayer.UpdateStatsAndProgressBar(CurrentPlayerStats.Elo.CurrentValue,"Kills", RankSettings.Rank_Difficulty.EloGainPerKill)
            else if(Increment = "Deaths",PlayerObj := player[Agent], PlayerObj.IsActive[], CustomPlayer := PlayerRankUi[PlayerObj]):
                    CustomPlayer.UpdateStatsAndProgressBar(CurrentPlayerStats.Elo.CurrentValue, "Deaths", RankSettings.Rank_Difficulty.EloLossPerDeath)     

    OnPlayerAdded(Agent:agent):void=
        if (PlayerObj := player[Agent], PlayerObj.IsActive[]):
             if(CustomPlayer := PlayerRankUi[PlayerObj]):
             else: 
                 if (FC := Agent.GetFortCharacter[]):
                    if(CurrentPlayerStats := PlayerStatsManager.GetPlayerStats[Agent]):   
                        
                     CustomPlayer:Custom_Player_Rank = Custom_Player_Rank{Player := Agent}
                     option:
                        set PlayerRankUi[PlayerObj] = CustomPlayer
                        
                     spawn{CustomPlayer.initiateRankSettings(RankSettings,Txt1)}
                     CustomPlayer.initiateUI(CurrentPlayerStats.Elo.CurrentValue)
                     
                     Print("Player Added")
    
            
      
    
    KillsMessage<localizes>(Value:int):message = "{Value}"
    DeathsMessage<localizes>(Value:int):message = "{Value}"
    EloMessage<localizes>(Value:int):message = "{Value}"
    KDMessage<localizes>(Value:float):message = "{Value}"
    TimeMessage<localizes>(Value:int):message = "{Value}"
    

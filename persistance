                        NbKill := PlayerTable.NbKill
                        NbDeath := NewDeath
                        NbKD := PlayerTable.NbKD
                    if(set PlayerStatMap2[Player] = NewStats):
                        var Dummy : int = 0

    UpdateNbKD(Agent : agent, NewKD : float) : void=
